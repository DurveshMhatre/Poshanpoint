NODE_ENV=development
PORT=5000

# Production DB (required when USE_IN_MEMORY_DB=false)
MONGO_URI=
USE_IN_MEMORY_DB=true
SEED_ON_STARTUP=true

# Frontend origins (comma-separated)
CLIENT_URL=http://localhost:3000
CLIENT_URLS=http://localhost:3000

# Auth
JWT_SECRET=replace-with-strong-secret
ADMIN_PHONES=9999999999
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Admin
STAFF_USERNAME=staff
STAFF_PASSWORD=Staff@12345
STAFF_NAME=Kitchen Staff
STAFF_LOGIN_RATE_LIMIT_MAX=10

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMS
SMS_PROVIDER=console
SMS_API_KEY=

# Rate limits
RATE_LIMIT_MAX=300
OTP_RATE_LIMIT_MAX=5
API_BODY_LIMIT=6mb
MAX_UPLOAD_IMAGE_BYTES=3145728
PUBLIC_SERVER_URL=http://localhost:5000
